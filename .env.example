# ────────────────────────────────────────────────────────────
# Application Environment
# ────────────────────────────────────────────────────────────
# Set to "development" locally, "production" on live servers.
APP_ENV=development

# ────────────────────────────────────────────────────────────
# Database
# ────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=helping_paws2
DB_USERNAME=helping_paws_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ────────────────────────────────────────────────────────────
# Session
# ────────────────────────────────────────────────────────────
# Set to "false" only during local HTTP development (no TLS).
SESSION_SECURE=true
SESSION_SAMESITE=Lax
SESSION_LIFETIME=3600
SESSION_NAME=HP_SESSION
